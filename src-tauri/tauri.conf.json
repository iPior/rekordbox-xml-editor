{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rekordbox XML Editor",
  "version": "0.1.0",
  "identifier": "com.example.rekordboxxmleditor",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rekordbox XML Editor",
        "width": 1500,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
